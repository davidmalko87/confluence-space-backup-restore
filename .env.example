# Confluence Space Backup & Restore Tool — Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# NEVER commit .env to version control!

# =============================================================
# Confluence Instance (used for both backup and restore)
# =============================================================

# Confluence Cloud base URL — MUST include the /wiki suffix, no trailing slash.
# Example: https://your-domain.atlassian.net/wiki
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki

# Email associated with your Atlassian account
CONFLUENCE_EMAIL=your-email@example.com

# API token — generate at: https://id.atlassian.com/manage-api-tokens
# This is the recommended auth for Confluence Cloud (Basic auth: email + token).
CONFLUENCE_API_TOKEN=

# Alternative: Cookie auth (only for SSO/SAML when Basic Auth is blocked).
# Copy from browser DevTools -> Network -> any /wiki request -> Cookie header.
# Leave empty if using API token (recommended). Cookies expire ~30 days.
CONFLUENCE_COOKIE_HEADER=

# SSL verification (set to false only for self-signed certs / corporate proxy)
CONFLUENCE_VERIFY_SSL=true

# =============================================================
# Backup Settings
# =============================================================

# Root directory for backups (relative or absolute path)
BACKUP_ROOT=./backups

# Items per API page (Confluence Cloud v2 caps at 250; default response is 25)
PAGE_SIZE=250

# Max retries for failed API calls and downloads
MAX_RETRIES=5

# Seconds to wait for a server response before retrying (0 = no timeout)
READ_TIMEOUT=30

# Seconds between API calls (rate-limit throttle)
API_DELAY=0.2

# Bytes per chunk when streaming attachment downloads (8 MiB)
CHUNK_SIZE=8388608

# Body format to read/write. 'storage' (XHTML) is recommended for round-trip
# fidelity and macro/ID remapping. 'atlas_doc_format' (ADF JSON) is also valid
# but can normalize/drop legacy macros.
BODY_FORMAT=storage

# What to include in backups
INCLUDE_ATTACHMENTS=true
INCLUDE_COMMENTS=true
INCLUDE_BLOGPOSTS=true
INCLUDE_RESTRICTIONS=true

# Page version history. When true, version METADATA (and bodies, if reachable)
# are saved as a read-only sidecar. NOTE: version history CANNOT be replayed on
# restore (Confluence has no version-injection API) — this is for reference only.
INCLUDE_VERSIONS=false

# =============================================================
# Native XML space export (OPTIONAL, off by default)
# =============================================================

# When true, each backup ALSO attempts a native Confluence XML space export and
# stores the resulting ZIP under <backup>/native/. This is a HIGH-FIDELITY DR
# artifact (preserves history/authors/timestamps) that you import MANUALLY via
# the Confluence UI ("Import a space"). It relies on an UNDOCUMENTED Atlassian
# endpoint that can change/break at any time, so it is best-effort: a failure is
# logged as a warning and never fails the REST backup. Leave false unless needed.
NATIVE_EXPORT=false

# Max seconds to wait for a native export to finish before giving up.
NATIVE_EXPORT_TIMEOUT=1800
